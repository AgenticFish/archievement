#!/usr/bin/env bash
set -euo pipefail

# Read stdin (a JSON object Claude Code passes in)
INPUT=$(cat)

# Extract cwd (with jq if available, fallback to grep+sed)
if command -v jq >/dev/null 2>&1; then
  CWD=$(printf '%s' "$INPUT" | jq -r '.cwd // empty')
else
  CWD=$(printf '%s' "$INPUT" | sed -n 's/.*"cwd"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -n1)
fi

# Fall back to the current directory if cwd was empty
if [ -z "${CWD:-}" ]; then
  CWD=$(pwd)
fi

PLUGIN_ROOT=${CLAUDE_PLUGIN_ROOT:-"$(cd "$(dirname "$0")/.." && pwd)"}

# Pass CWD via env var so paths containing apostrophes or other shell-sensitive
# characters don't corrupt the inlined JS string. The `|| true` guard keeps
# `set -e` from killing the hook when the node call exits non-zero (e.g.
# CLAUDE_PLUGIN_DATA missing on Claude Code < 2.1.78); we degrade silently to
# empty context.
ADDITIONAL_CONTEXT=$(ARCHIEVEMENT_HOOK_CWD="$CWD" node --input-type=module -e "
import { runSessionStart } from '${PLUGIN_ROOT}/lib/hooks/session-start.js';
const out = await runSessionStart({
  cwd: process.env.ARCHIEVEMENT_HOOK_CWD ?? '',
  now: new Date().toISOString().slice(0, 10),
});
process.stdout.write(out.additionalContext);
" 2>/dev/null) || ADDITIONAL_CONTEXT=""

# If empty, just exit silently
if [ -z "$ADDITIONAL_CONTEXT" ]; then
  exit 0
fi

# Emit hook response JSON
jq -n --arg ctx "$ADDITIONAL_CONTEXT" '{"hookSpecificOutput": {"hookEventName": "SessionStart", "additionalContext": $ctx}}'
